# SpecialtyPulse Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Domo API credentials ---
# Create these at https://developer.domo.com/manage-clients
DOMO_CLIENT_ID=your-client-id-here
DOMO_CLIENT_SECRET=your-client-secret-here

# --- Domo DataSet IDs ---
# After creating DataSets in Domo, paste their IDs here.
# Find IDs: Data Center > click DataSet > URL contains the ID
DOMO_DATASET_ID_MART=your-mart-dataset-id
DOMO_DATASET_ID_VERIFY=your-verify-dataset-id

# --- Databricks (for Airflow operator) ---
# Find at: Databricks workspace > User Settings > Developer > Access Tokens
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-personal-access-token

# --- Databricks notebook path ---
# Base path where notebooks are stored in the workspace
# Default uses current user's home directory
DATABRICKS_NOTEBOOK_BASE_PATH=/Users/your-email@company.com/specialtypulse

# --- Optional: override default behavior ---
# CMS_PUF_VOLUME_PATH=/Volumes/main/specialtypulse_raw/cms_puf
# DOMO_INSTANCE=your-instance.domo.com
